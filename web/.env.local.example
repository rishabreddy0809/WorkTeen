# WorkTeen Firebase Config
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values from:
#   Firebase Console → Your Project → Project Settings
#   → General tab → "Your apps" section → SDK setup and configuration → Config
#
# These NEXT_PUBLIC_ values are safe to expose to the browser.
# Firebase security is enforced by Firestore security rules, not by hiding these keys.

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin password — choose something strong.
# Verified SERVER-SIDE only via /api/admin-auth — never exposed to the client bundle.
# Never commit .env.local to git. Set this in Vercel → Settings → Environment Variables.
# IMPORTANT: Do NOT prefix with NEXT_PUBLIC_ — that would leak it into the JS bundle.
ADMIN_PASSWORD=choose_a_strong_password_here

# ─── Firebase Admin SDK (server-side only — NOT prefixed with NEXT_PUBLIC_) ───
#
# Used by /api/notify-job-approval to send FCM push notifications when a job
# listing is approved. These values come from a service account key JSON file
# downloaded from Firebase Console → Project Settings → Service Accounts →
# "Generate new private key".
#
# Steps:
#   1. Firebase Console → Project Settings (gear) → Service accounts tab
#   2. Click "Generate new private key" → confirm → JSON file downloads
#   3. Copy the three values below from that JSON file
#   4. Delete the downloaded JSON (never commit it)
#   5. Add the same three vars to Vercel: Settings → Environment Variables
#
# FIREBASE_PROJECT_ID
#   The "project_id" field from the JSON. Same as your NEXT_PUBLIC_FIREBASE_PROJECT_ID.
FIREBASE_PROJECT_ID=your_project_id

# FIREBASE_CLIENT_EMAIL
#   The "client_email" field from the JSON.
#   Looks like: firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# FIREBASE_PRIVATE_KEY
#   The "private_key" field from the JSON.
#   MUST be wrapped in double-quotes in .env.local so the \n newlines are preserved.
#   In Vercel's dashboard, paste the raw value (with real newlines) — no quotes needed.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
